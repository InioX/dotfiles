{
  "layer": "top",
  "position": "top",
  "margin-left": 0,
  "margin-bottom": 0,
  "margin-top": 0,
  "modules-left": [
    "hyprland/workspaces",
    "custom/sep",
    "wlr/taskbar",
  ],
  "modules-center": [],
  "modules-right": [
    // "custom/next",
    // "custom/play_pause",
    // "custom/previous",
    "tray",
    "cpu",
    "custom/sep",
    "memory",
    "custom/sep",
    "battery#icon",
    "battery#text",
    "custom/sep",
    "custom/wl-gammarelay-brightness#icon",
    "custom/wl-gammarelay-brightness#text",
    "custom/sep",
    "custom/wl-gammarelay-temperature#icon",
    "custom/wl-gammarelay-temperature#text",
    "custom/sep",
    "pulseaudio#icon",
    "pulseaudio#text",
    "custom/sep",
    "clock",
  ],
  "tray": {
    "icon-size": 18,
    "spacing": 5
  },
  "wlr/taskbar": {
    "format": "{name}",
    "on-click": "activate",
    "on-click-middle": "close",
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  "cpu": {
    "interval": 1,
    "format": "Ôíľ  {}%",
  },
  "memory": {
    "interval": 30,
    "format": "ÓŅÖ  {used:0.1f}G/{total:0.1f}G ({percentage}%, {swapPercentage}%)"
  },
  "custom/next": {
    "format": "ůįí≠",
    "on-click": "playerctl next",
  },
  "custom/previous": {
    "format": "ůįíģ",
    "on-click": "playerctl previous",
  },
  "custom/play_pause": {
    "format": "{}",
    "return-type": "json",
    "exec": "mediaplayer-waybar",
    "on-click": "playerctl play-pause",
  },
  "battery#icon": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{icon}",
    "format-charging": "{icon}ůĪźĆ",
    "format-plugged": "{icon}ůĪźč",
    "format-warning": "{icon} ůįÄ™",
    "format-critical": "{icon} ůįÄ™",
    "format-icons": [
      "ůįĀļ",
      "ůįĀľ",
      "ůįĀĺ",
      "ůįāÄ",
      "ůįāā"
    ]
  },
  "battery#text": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{capacity}%",
  },
  "custom/power": {
    "format": "ůįź•",
  },
  "custom/menu": {
    "format": "ůįćú"
  },
  "custom/sep": {
    "format": "|"
  },
  "custom/mode": {
    "format": "ůįĒé",
    "on-click": "hyprctl dispatch exec ~/.config/hypr/scripts/switch-mode.sh"
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "active-only": false,
    "all-outputs": true,
    "on-click": "activate",
    "format": "{icon}",
    // "format-icons": {
    //   "1": "ůįÖī",
    //   "2": "ůįąģ",
    //   "3": "ůįÖī",
    //   "4": "ůįĖü",
    //   "5": "ůįÖļ",
    //   "6": "ůįČč",
    //   "7": "ÔĄĎ",
    //   "8": "ÔĄĎ",
    //   "9": "ÔĄĎ",
    //   "10": "ÔĄĆ",
    //   "default": "ÔĄĆ",
    // },
    "persistent-workspaces": {
      "eDP-1": [
        1,
        2,
        3,
        4,
        5
      ]
    },
  },
  "clock": {
    "format": "{:%H:%M:%S}",
    "tooltip-format": "{:%d-%m-%Y}",
    "interval": 1,
  },
  "pulseaudio#icon": {
    "format": "{icon}",
    "format-muted": "ůįĚü",
    "scroll-step": 1,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-middle": "pavucontrol",
    "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "format-icons": {
      "headphone": "ůįčč",
      "hands-free": "ÔÄ•",
      "headset": "ůįčč",
      "phone": "Ôāē",
      "portable": "Ôāē",
      "car": "ÔÜĻ",
      "default": [
        "ůįĖÄ",
        "ůįĖÄ",
        "ůįēĺ",
        "ůįēĺ"
      ]
    },
  },
  "pulseaudio#text": {
    "format": "{volume}",
    "format-muted": "{volume}",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-middle": "pavucontrol",
    "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
  },
  "custom/wl-gammarelay-temperature#icon": {
    "format": "ůįĒŹ",
    "on-scroll-up": "~/.config/hypr/scripts/brightness.sh temperature-up 100",
    "on-scroll-down": "~/.config/hypr/scripts/brightness.sh temperature-down 100"
  },
  "custom/wl-gammarelay-temperature#text": {
    "format": "{}",
    "exec": "wl-gammarelay-rs watch {t}",
    "on-scroll-up": "~/.config/hypr/scripts/brightness.sh temperature-up 100",
    "on-scroll-down": "~/.config/hypr/scripts/brightness.sh temperature-down 100"
  },
  "custom/wl-gammarelay-brightness#icon": {
    "format": "ůįÉü",
    "on-scroll-up": "~/.config/hypr/scripts/brightness.sh brightness-up 0.05",
    "on-scroll-down": "~/.config/hypr/scripts/brightness.sh brightness-down 0.05"
  },
  "custom/wl-gammarelay-brightness#text": {
    "format": "{}",
    "exec": "wl-gammarelay-rs watch {bp}",
    "on-scroll-up": "~/.config/hypr/scripts/brightness.sh brightness-up 100",
    "on-scroll-down": "~/.config/hypr/scripts/brightness.sh temperature-down 100"
  },
}